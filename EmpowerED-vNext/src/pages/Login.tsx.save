import { useState } from "react";
import { useNavigate } from "react-router-dom";
import { useAuth } from "@/lib/auth";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Sparkles, MailCheck } from "lucide-react";

export default function Login() {
  const { sendOtp, verifyOtp, mode } = useAuth();
  const navigate = useNavigate();
  const [step, setStep] = useState<"email" | "otp">("email");
  const [email, setEmail] = useState("");
  const [code, setCode] = useState("");
  const [demoCode, setDemoCode] = useState("");
  const [error, setError] = useState("");
  const [busy, setBusy] = useState(false);

  const requestCode = async (e: React.FormEvent) => {
    e.preventDefault(); setError(""); setBusy(true);
    const r = await sendOtp(email);
    setBusy(false);
    if (!r.ok) { setError(r.error || "Could not send code."); return; }
    if (r.demoCode) setDemoCode(r.demoCode);
    setStep("otp");
  };

  const submitCode = async (e: React.FormEvent) => {
    e.preventDefault(); setError(""); setBusy(true);
    const r = await verifyOtp(email, code);
    setBusy(false);
    if (r.ok) navigate("/");
    else setError(r.error || "Verification failed.");
  };

  return (
    <div className="min-h-screen grid md:grid-cols-2">
      <div className="hidden md:flex flex-col justify-center bg-brand-dark text-white p-12">
        <div className="text-4xl font-bold mb-2">EmpowerED</div>
        <div className="text-lg text-white/80 mb-6">AI-Powered Internal Resource Management</div>
        <p className="text-white/60 max-w-sm text-sm leading-relaxed">
          Secure, passwordless access via email one-time code. Only administrator-approved
          email addresses can sign in.
        </p>
      </div>
      <div className="flex items-center justify-center p-8 bg-slate-50">
        <div className="w-full max-w-sm bg-white rounded-xl border border-slate-200 shadow-sm p-6">
          <div className="flex items-center gap-2 text-brand mb-4"><Sparkles size={20} /><span className="font-semibold">Sign in</span></div>

          {step === "email" && (
            <form onSubmit={requestCode}>
              <label className="text-sm text-slate-600">Work email</label>
              <Input className="mt-1 mb-4" value={email} onChange={(e) => setEmail(e.target.value)} placeholder="you@company.com" autoFocus />
              {error && <div className="text-sm text-red-600 mb-3">{error}</div>}
              <Button type="submit" className="w-full" disabled={busy}>{busy ? "Sending…" : "Send one-time code"}</Button>
            </form>
          )}

          {step === "otp" && (
            <form onSubmit={submitCode}>
              <div className="flex items-center gap-2 text-emerald-600 text-sm mb-3"><MailCheck size={16} /> Code sent to {email}</div>
              {demoCode && (
                <div className="text-xs bg-amber-50 border border-amber-200 text-amber-700 rounded p-2 mb-3">
                  Demo mode (no Supabase configured): your code is <b>{demoCode}</b>
                </div>
              )}
              <label className="text-sm text-slate-600">Enter 6-digit code</label>
              <Input className="mt-1 mb-4 tracking-widest" value={code} onChange={(e) => setCode(e.target.value)} placeholder="______" maxLength={6} autoFocus />
              {error && <div className="text-sm text-red-600 mb-3">{error}</div>}
              <Button type="submit" className="w-full" disabled={busy}>{busy ? "Verifying…" : "Verify & sign in"}</Button>
              <button type="button" onClick={() => { setStep("email"); setError(""); setCode(""); }}
                className="mt-3 text-xs text-slate-500 hover:text-brand">Use a different email</button>
            </form>
          )}

          <div className="mt-4 text-xs text-slate-400">
            {mode === "supabase" ? "Secured by Supabase Email OTP." : "Running in demo mode. Try admin@company.com or manager@company.com."}
          </div>
        </div>
      </div>
    </div>
  );
}

{mode === "supabase"
  ? "Secured by Supabase Email OTP."
  : "Running in demo mode. Try admin@company.com or manager@company.com."
}

"Secured by Supabase Email OTP."

